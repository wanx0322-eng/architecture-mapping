{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.example/architecture-mapping-zh/moe_decision.schema.json",
  "title": "Mapping MoE Decision",
  "type": "object",
  "required": ["schema_version", "task_id", "task_type", "activated_experts", "hard_constraints", "candidates", "decision", "quality_score", "confidence", "ready_for_delivery"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "task_id": {"type": "string", "minLength": 1},
    "task_type": {"type": "string", "minLength": 1},
    "activated_experts": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string"}},
    "hard_constraints": {"type": "array", "items": {"type": "string"}},
    "vetoes": {"type": "array", "items": {"type": "string"}},
    "candidates": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "scores", "total", "strengths", "risks"],
        "properties": {
          "id": {"type": "string"},
          "scores": {"type": "object"},
          "total": {"type": "number", "minimum": 0, "maximum": 100},
          "strengths": {"type": "array", "items": {"type": "string"}},
          "risks": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "decision": {"enum": ["select", "merge", "revise", "ask_user", "block"]},
    "selected_candidate": {"type": ["string", "null"]},
    "rationale": {"type": "string"},
    "quality_score": {"type": "number", "minimum": 0, "maximum": 100},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "user_choice_required": {"type": "boolean"},
    "ready_for_delivery": {"type": "boolean"}
  },
  "additionalProperties": false
}
